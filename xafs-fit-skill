#!/usr/bin/env bash
# xafs-fit-skill -- Self-bootstrapping wrapper
# Creates venv, installs deps on first run.
set -eu

SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV_DIR="${SKILL_DIR}/.venv"

bootstrap() {
    echo "[xafs-fit-skill] Bootstrapping..." >&2
    if ! command -v python3 >/dev/null 2>&1; then
        echo "[xafs-fit-skill] ERROR: python3 not found. Install Python >= 3.9." >&2
        exit 1
    fi
    python3 -m venv "${VENV_DIR}" >&2
    "${VENV_DIR}/bin/pip" install --quiet -r "${SKILL_DIR}/requirements.txt" >&2
    echo "[xafs-fit-skill] Bootstrap complete." >&2
}

if [ ! -d "${VENV_DIR}" ]; then
    bootstrap
fi

exec "${VENV_DIR}/bin/python3" "$@"
